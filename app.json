{
  "expo": {
    "name": "veil",
    "slug": "veil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon.png",
    "scheme": "veil",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/adaptive-icon.png",
      "bundleIdentifier": "com.belash.veil"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "allowBackup": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Veil imports the photos you select into your on-device encrypted vault."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Veil saves the photos you export from your vault back to your device library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "react-native-share",
        {
          "ios": [],
          "android": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
